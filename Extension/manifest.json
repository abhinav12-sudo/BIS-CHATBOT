{
    "manifest_version": 3,
    "name": "BIS Product Checker",
    "version": "1.0",
    "description": "Check if a product is BIS certified",
    "permissions": ["activeTab"],
    "action":{
        "default_popup": "popup.html"
    },
    "content_scripts":[
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"]
        }
    ]
}